---
import { siteConfig } from "../../config/site";

const { featureHighlights } = siteConfig;
---

<section class="bg-surface px-6 py-16 sm:px-8 lg:px-12" aria-labelledby="feature-highlights-heading">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl">
      <p class="font-display text-sm font-semibold uppercase tracking-normal text-brand-700">
        Capabilities
      </p>
      <h2 id="feature-highlights-heading" class="mt-4 font-display text-3xl font-bold leading-tight tracking-normal text-ink-950 sm:text-4xl">
        {featureHighlights.heading}
      </h2>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {
        featureHighlights.items.map((item) => (
          <article class="rounded-lg border border-ink-200 bg-white p-6 shadow-soft">
            <div class="flex items-start gap-4">
              <span class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-700" aria-hidden="true">
                <svg viewBox="0 0 24 24" class="h-5 w-5">
                  <path d="m6 12.5 3.5 3.5L18 7.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <h3 class="font-display text-xl font-semibold tracking-normal text-ink-950">
                  {item.heading}
                </h3>
                <p class="mt-3 text-base leading-7 text-ink-600">
                  {item.body}
                </p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
