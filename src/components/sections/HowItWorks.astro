---
import { siteConfig } from "../../config/site";

const { howItWorks } = siteConfig;
---

<section class="bg-surface-muted px-6 py-16 sm:px-8 lg:px-12" aria-labelledby="how-it-works-heading">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl">
      <p class="font-display text-sm font-semibold uppercase tracking-normal text-brand-700">
        Process
      </p>
      <h2 id="how-it-works-heading" class="mt-4 font-display text-3xl font-bold leading-tight tracking-normal text-ink-950 sm:text-4xl">
        {howItWorks.heading}
      </h2>
    </div>

    <ol class="relative mt-12 grid gap-5 md:grid-cols-4 md:gap-4">
      <span class="absolute left-12 right-12 top-8 hidden h-px bg-ink-200 md:block" aria-hidden="true"></span>
      {
        howItWorks.steps.map((step, index) => (
          <li class="relative">
            <article class="h-full rounded-lg border border-ink-200 bg-white p-6 shadow-soft">
              <div class="flex h-16 w-16 items-center justify-center rounded-lg border border-brand-100 bg-brand-50 font-display text-lg font-bold text-brand-700">
                {String(index + 1).padStart(2, "0")}
              </div>
              <h3 class="mt-6 font-display text-xl font-semibold tracking-normal text-ink-950">
                {step.heading}
              </h3>
              <p class="mt-3 text-base leading-7 text-ink-600">
                {step.body}
              </p>
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>
