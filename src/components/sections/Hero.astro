---
import { siteConfig } from "../../config/site";

const { name, assets, hero } = siteConfig;
---

<section
  id="hero"
  class="relative isolate overflow-hidden bg-background px-6 py-20 sm:px-8 sm:py-24 lg:px-12"
  aria-labelledby="hero-heading"
>
  <div class="mx-auto grid max-w-6xl items-center gap-14 lg:grid-cols-[minmax(0,1.05fr)_minmax(18rem,0.75fr)]">
    <div class="max-w-3xl">
      <a href="/" class="mb-12 inline-flex items-center gap-3 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-ring focus-visible:ring-offset-4">
        <img src={assets.logo} alt={name} class="h-10 w-auto" width="165" height="40" />
      </a>

      <p class="mb-5 font-display text-sm font-semibold uppercase tracking-normal text-primary">
        {hero.tagline}
      </p>

      <h1
        id="hero-heading"
        class="max-w-4xl font-display text-5xl font-bold leading-tight tracking-normal text-foreground sm:text-6xl lg:text-7xl"
      >
        {hero.headline}
      </h1>

      <p class="mt-7 max-w-2xl text-lg leading-8 text-foreground-muted sm:text-xl">
        {hero.body}
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a
          href={hero.cta.href}
          class="inline-flex min-h-12 items-center justify-center rounded-lg bg-primary px-6 py-3 text-base font-semibold text-primary-foreground shadow-soft transition hover:bg-primary-hover focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-ring focus-visible:ring-offset-4"
        >
          {hero.cta.label}
        </a>
      </div>
    </div>

    <div class="relative min-h-72 lg:min-h-96" aria-hidden="true">
      <div class="absolute inset-x-5 top-8 h-56 rounded-[2rem] border border-border bg-card shadow-soft sm:h-64 lg:inset-x-0 lg:h-72"></div>
      <div class="absolute left-0 top-0 h-28 w-28 rounded-[1.75rem] bg-primary-strong p-6 shadow-soft sm:h-32 sm:w-32">
        <img src={assets.favicon} alt="" class="h-full w-full" width="80" height="80" />
      </div>
      <div class="absolute bottom-4 right-0 w-64 rounded-2xl border border-border bg-card p-5 shadow-soft sm:w-72">
        <p class="text-sm font-semibold text-foreground">Talk</p>
        <div class="mt-4 h-2 rounded-full bg-primary-subtle">
          <div class="h-2 w-2/3 rounded-full bg-primary-active"></div>
        </div>
        <p class="mt-5 text-sm leading-6 text-muted-foreground">Plan, build, deploy, and operate from one conversation.</p>
      </div>
      <div class="absolute right-8 top-20 flex gap-3">
        <span class="h-4 w-4 rounded-full bg-primary-active"></span>
        <span class="h-4 w-4 rounded-full bg-accent"></span>
        <span class="h-4 w-4 rounded-full bg-accent-warm"></span>
      </div>
    </div>
  </div>
</section>
