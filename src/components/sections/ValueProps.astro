---
import { siteConfig } from "../../config/site";

const [githubNative, sdlcAutonomy, codeOwnership] = siteConfig.valueProps;
---

<section class="bg-surface px-6 py-16 sm:px-8 lg:px-12" aria-labelledby="value-props-heading">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl">
      <p class="font-display text-sm font-semibold uppercase tracking-normal text-primary">
        Value propositions
      </p>
      <h2 id="value-props-heading" class="mt-4 font-display text-3xl font-bold leading-tight tracking-normal text-foreground sm:text-4xl">
        Built for founder-led software delivery
      </h2>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      <article class="rounded-lg border border-border bg-surface-raised p-6 shadow-soft">
        <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-primary-soft text-primary">
          <svg viewBox="0 0 24 24" class="h-6 w-6" aria-hidden="true">
            <path d="M7 8.5h10M7 12h7M7 15.5h5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            <path d="M5.5 4.75h13A1.75 1.75 0 0 1 20.25 6.5v11a1.75 1.75 0 0 1-1.75 1.75h-13A1.75 1.75 0 0 1 3.75 17.5v-11A1.75 1.75 0 0 1 5.5 4.75Z" fill="none" stroke="currentColor" stroke-width="1.8" />
          </svg>
        </div>
        <h3 class="mt-5 font-display text-xl font-semibold tracking-normal text-foreground">
          {githubNative.heading}
        </h3>
        <p class="mt-3 text-base leading-7 text-muted-foreground">
          {githubNative.body}
        </p>
      </article>

      <article class="rounded-lg border border-border bg-surface-raised p-6 shadow-soft">
        <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-primary-soft text-primary">
          <svg viewBox="0 0 24 24" class="h-6 w-6" aria-hidden="true">
            <path d="M5 12a7 7 0 0 1 12-4.9M19 12a7 7 0 0 1-12 4.9" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            <path d="M17 3.75v3.5h-3.5M7 20.25v-3.5h3.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <h3 class="mt-5 font-display text-xl font-semibold tracking-normal text-foreground">
          {sdlcAutonomy.heading}
        </h3>
        <p class="mt-3 text-base leading-7 text-muted-foreground">
          {sdlcAutonomy.body}
        </p>
      </article>

      <article class="rounded-lg border border-border bg-surface-raised p-6 shadow-soft">
        <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-primary-soft text-primary">
          <svg viewBox="0 0 24 24" class="h-6 w-6" aria-hidden="true">
            <path d="M12 3.75 5.25 6.5v5.35c0 4.1 2.75 6.9 6.75 8.4 4-1.5 6.75-4.3 6.75-8.4V6.5L12 3.75Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
            <path d="m9.25 12.25 1.85 1.85 3.9-4.1" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <h3 class="mt-5 font-display text-xl font-semibold tracking-normal text-foreground">
          {codeOwnership.heading}
        </h3>
        <p class="mt-3 text-base leading-7 text-muted-foreground">
          {codeOwnership.body}
        </p>
      </article>
    </div>
  </div>
</section>
